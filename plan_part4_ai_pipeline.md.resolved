### 5.5 Confirm Endpoint

```typescript
// src/app/api/chat/confirm/route.ts

export async function POST(req: Request) {
  const { businessId, transactionData } = await req.json();
  // transactionData is the validated AIResponseSchema.transaction object

  const adminDb = createServiceRoleClient(); // bypasses RLS for atomic ops

  // Begin transaction (use Supabase RPC for atomicity)
  for (const item of transactionData.items) {
    // 1. Resolve or create product
    let variantId = item.matched_variant_id;

    if (item.is_new_product) {
      const product = await adminDb.from('products').insert({
        business_id: businessId,
        name: item.product_name,
      }).select().single();

      const variant = await adminDb.from('product_variants').insert({
        product_id: product.data.id,
        business_id: businessId,
        size: parseVariantAttr(item.variant_descriptor, 'size'),
        scent: parseVariantAttr(item.variant_descriptor, 'scent'),
        color: parseVariantAttr(item.variant_descriptor, 'color'),
        cost_price: transactionData.type === 'purchase' ? item.unit_price : null,
        selling_price: transactionData.type === 'sale' ? item.unit_price : null,
      }).select().single();

      variantId = variant.data.id;

      // Create initial stock level
      await adminDb.from('stock_levels').insert({
        variant_id: variantId,
        location_id: defaultLocationId,
        business_id: businessId,
        quantity: 0,
      });
    }

    // 2. Create transaction
    const txn = await adminDb.from('transactions').insert({
      business_id: businessId,
      location_id: resolvedLocationId,
      type: transactionData.type,
      status: 'confirmed',
      supplier_id: resolvedSupplierId,
      customer_id: resolvedCustomerId,
      total_amount: transactionData.total_amount,
      created_by: userId,
      source: 'chat',
    }).select().single();

    // 3. Create transaction items
    await adminDb.from('transaction_items').insert({
      transaction_id: txn.data.id,
      variant_id: variantId,
      quantity: item.quantity,
      unit_price: item.unit_price,
      total_price: item.total_price,
    });

    // 4. Update stock levels
    const stockDelta = transactionData.type === 'purchase' ? item.quantity :
                       transactionData.type === 'sale' ? -item.quantity :
                       item.quantity; // adjustment

    // Use RPC for atomic update with negative check
    await adminDb.rpc('update_stock_level', {
      p_variant_id: variantId,
      p_location_id: resolvedLocationId,
      p_delta: stockDelta,
    });
  }

  // 5. Post-transaction: check for low stock insights
  await checkLowStockInsights(adminDb, businessId, transactionData.items);

  return Response.json({ success: true, transactionId: txn.data.id });
}
```

**Atomic stock update RPC** (added as migration 005):

```sql
-- 005_stock_update_rpc.sql

CREATE OR REPLACE FUNCTION update_stock_level(
  p_variant_id UUID,
  p_location_id UUID,
  p_delta INTEGER
) RETURNS INTEGER AS $$
DECLARE
  new_quantity INTEGER;
BEGIN
  UPDATE stock_levels
  SET quantity = quantity + p_delta,
      updated_at = NOW()
  WHERE variant_id = p_variant_id AND location_id = p_location_id
  RETURNING quantity INTO new_quantity;

  IF new_quantity < 0 THEN
    RAISE EXCEPTION 'Insufficient stock: would result in % units', new_quantity;
  END IF;

  RETURN new_quantity;
END;
$$ LANGUAGE plpgsql;
```

---

### 5.6 Error Handling & Retry Logic

| Error | Detection | Action |
|-------|-----------|--------|
| Rate limit (429) | Anthropic SDK throws `RateLimitError` | Exponential backoff: wait 1s, 2s, 4s. Max 3 retries. Then return "AI is busy" |
| Timeout (>15s) | `AbortController` with 15s timeout | Abort stream, return "Request timed out" |
| Malformed JSON | `JSON.parse` throws or Zod validation fails | Retry once: append "RESPOND WITH VALID JSON ONLY" to messages. If still fails, return raw text as confirmation_message with `needs_clarification: true` |
| Network error | SDK throws `APIConnectionError` | Return "Connection error, please try again" |
| Context too long | SDK throws `BadRequestError` with "context" | Truncate history to 10 messages, retry |

---

### 5.7 Cost Optimization

| Strategy | Savings | Implementation |
|----------|---------|----------------|
| Limit system prompt products to 50 | ~30% fewer input tokens | Already specified in prompt builder |
| Truncate history to 20 messages | Bounded input cost | Already in `conversationHistory.ts` |
| Use `max_tokens: 1024` | Cap output cost | Already in API call |
| Cache system prompt per business | Avoid rebuilding identical prompts | In-memory cache with 5-min TTL |
| Skip AI for exact command matches | Zero API cost for simple queries | Pattern match "check stock [product]" → direct DB query |

**Estimated cost per message**: ~8K input tokens + ~500 output tokens = ~$0.004 per interaction at Sonnet pricing. At 100 messages/day/business with 1,000 businesses = $400/day. This is manageable but should be monitored. Per-business usage caps can be added if needed.

