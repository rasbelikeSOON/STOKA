### 5.3 Conversation History Management

```typescript
// src/lib/ai/conversationHistory.ts

const MAX_MESSAGES = 20;
const MAX_HISTORY_TOKENS_ESTIMATE = 4000; // ~16,000 chars

export async function getConversationHistory(
  supabase: SupabaseClient,
  businessId: string
): Promise<{ role: 'user' | 'assistant'; content: string }[]> {
  const { data: messages } = await supabase
    .from('chat_messages')
    .select('role, content')
    .eq('business_id', businessId)
    .in('role', ['user', 'assistant'])
    .order('created_at', { ascending: false })
    .limit(MAX_MESSAGES);

  if (!messages) return [];

  // Reverse to chronological order
  const ordered = messages.reverse();

  // Truncate if total chars exceed estimate
  let totalChars = 0;
  const trimmed = [];
  for (const msg of ordered.reverse()) {
    totalChars += msg.content.length;
    if (totalChars > 16000) break; // ~4000 tokens
    trimmed.unshift(msg);
  }

  return trimmed.map(m => ({
    role: m.role as 'user' | 'assistant',
    content: m.content,
  }));
}
```

Token management: System prompt ≈ 2,500 tokens. History ≈ 4,000 tokens max. Current message ≈ 100 tokens. Max output ≈ 1,024 tokens. **Total per request: ≈ 7,600 tokens.** Well within `claude-sonnet-4-6` limits.

