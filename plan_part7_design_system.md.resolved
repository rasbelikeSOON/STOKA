# Part 7 — Design System Implementation

---

## Design System Implementation

### 7.1 Global CSS Variables (`src/app/globals.css`)

```css
@tailwind base;
@tailwind components;
@tailwind utilities;

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap');

:root {
  /* Brand Core */
  --stoka-blue: #4F46E5;
  --stoka-blue-dark: #3730A3;
  --stoka-teal: #0F766E;
  --stoka-teal-light: #14B8A6;
  --stoka-green: #10B981;
  --stoka-amber: #F59E0B;
  --stoka-red: #EF4444;

  /* Surfaces — Light Mode (default) */
  --bg-base: #F0F0F0;
  --bg-app: #F9FAFB;
  --surface: #FFFFFF;
  --surface-hover: #F3F4F6;
  --border: #E5E7EB;
  --border-strong: #D1D5DB;

  /* Surfaces — Dark Mode (Dashboard) */
  --dark-bg: #12121F;
  --dark-surface: #1A1A2E;
  --dark-sidebar: #1C1C2E;
  --dark-border: rgba(255, 255, 255, 0.08);

  /* Text */
  --text-primary: #111827;
  --text-secondary: #374151;
  --text-muted: #6B7280;
  --text-dark-primary: #FFFFFF;
  --text-dark-muted: #94A3B8;

  /* Operation Tile Pastels */
  --tile-purchase: #FEF3C7;
  --tile-sale: #CCFBF1;
  --tile-stock: #EDE9FE;
  --tile-adjust: #FFE4E6;
  --tile-purchase-icon: #D97706;
  --tile-sale-icon: #0F766E;
  --tile-stock-icon: #7C3AED;
  --tile-adjust-icon: #E11D48;

  /* Chat */
  --bubble-user: #4F46E5;
  --bubble-ai: #FFFFFF;
  --bubble-ai-border: #E5E7EB;
}
```

### 7.2 Tailwind Config Extension (`tailwind.config.ts`)

```typescript
import type { Config } from 'tailwindcss';

const config: Config = {
  darkMode: 'class',
  content: ['./src/**/*.{ts,tsx}'],
  theme: {
    extend: {
      fontFamily: {
        sans: ['Inter', 'system-ui', 'sans-serif'],
        mono: ['JetBrains Mono', 'monospace'],
      },
      colors: {
        brand: {
          blue: 'var(--stoka-blue)',
          'blue-dark': 'var(--stoka-blue-dark)',
          teal: 'var(--stoka-teal)',
          'teal-light': 'var(--stoka-teal-light)',
          green: 'var(--stoka-green)',
          amber: 'var(--stoka-amber)',
          red: 'var(--stoka-red)',
        },
        surface: {
          base: 'var(--bg-base)',
          app: 'var(--bg-app)',
          DEFAULT: 'var(--surface)',
          hover: 'var(--surface-hover)',
        },
        dark: {
          bg: 'var(--dark-bg)',
          surface: 'var(--dark-surface)',
          sidebar: 'var(--dark-sidebar)',
          border: 'var(--dark-border)',
        },
        tile: {
          purchase: 'var(--tile-purchase)',
          sale: 'var(--tile-sale)',
          stock: 'var(--tile-stock)',
          adjust: 'var(--tile-adjust)',
          'purchase-icon': 'var(--tile-purchase-icon)',
          'sale-icon': 'var(--tile-sale-icon)',
          'stock-icon': 'var(--tile-stock-icon)',
          'adjust-icon': 'var(--tile-adjust-icon)',
        },
        bubble: {
          user: 'var(--bubble-user)',
          ai: 'var(--bubble-ai)',
          'ai-border': 'var(--bubble-ai-border)',
        },
      },
      borderColor: {
        DEFAULT: 'var(--border)',
        strong: 'var(--border-strong)',
      },
      textColor: {
        primary: 'var(--text-primary)',
        secondary: 'var(--text-secondary)',
        muted: 'var(--text-muted)',
      },
      letterSpacing: {
        display: '-0.02em',
      },
    },
  },
  plugins: [],
};

export default config;
```

