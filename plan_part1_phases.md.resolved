**Middleware logic (`src/middleware.ts`):**

```typescript
// Pseudocode — actual implementation uses @supabase/ssr
const publicRoutes = ['/', '/signin', '/signup', '/forgot-password',
  '/reset-password', '/pricing', '/terms', '/privacy', '/invite'];

export async function middleware(req) {
  const supabase = createServerClient(/* cookies */);
  const { data: { user } } = await supabase.auth.getUser();

  if (!user && !isPublicRoute(req.nextUrl.pathname)) {
    return redirect('/signin');
  }

  if (user && isAuthRoute(req.nextUrl.pathname)) {
    return redirect('/app/chat');
  }
}
```

